# ── Phoenix Capital-Guard — BNB trading agent ───────────────────────────────
# Copy to .env and fill. NEVER commit .env.

# --- CMC AI Agent Hub ---
CMC_API_KEY=                      # CoinMarketCap Agent Hub key (free for hackathon period)
CMC_BASE=https://pro-api.coinmarketcap.com

# --- Phoenix Zero safety oracle (our production x402 endpoint) ---
PHOENIX_SAFE_URL=https://rtt.phoenix-ai.work/api/v1/safe
PHOENIX_FEED_URL=https://rtt.phoenix-ai.work/api/public-feed
PHOENIX_API_KEY=                  # tier key if required; public-feed works without

# --- x402 payment (pay-per-safety-check) ---
X402_ENABLED=1
X402_PAYER_PRIVKEY=               # key that funds x402 micro-payments (USDC on Base)
X402_ASSET=USDC

# --- Trust Wallet Agent Kit (TWAK) — self-custody execution on BSC ---
TWAK_MODE=rest                    # rest | cli | mcp
TWAK_REST_URL=http://127.0.0.1:8080
TWAK_AGENT_PRIVKEY=               # self-custody signing key (agent wallet). Stays local.
BSC_RPC=https://bsc-dataseed.bnbchain.org
BSC_CHAIN_ID=56

# --- Risk guards (capital-protection — the 30% DQ edge) ---
MAX_DRAWDOWN_PCT=25               # hard stop BEFORE the 30% DQ line
PER_TRADE_USD=25                  # max notional per trade
DAILY_TRADES_MAX=12
SLIPPAGE_BPS=50                   # 0.50%
TOKEN_ALLOWLIST=USDT,USDC,WBNB,CAKE,ETH   # BEP-20 from the competition's 149-token list

# --- Loop ---
CHECK_INTERVAL=60                 # seconds between cycles
DRY_RUN=1                         # 1 = simulate (no on-chain), 0 = live BSC execution
